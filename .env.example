PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://wb_user:changeme@localhost:5432/wb_db
POSTGRES_DB=wb_db
POSTGRES_USER=wb_user
POSTGRES_PASSWORD=changeme

# Better Auth — generate secret: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-key-at-least-32-characters-here
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth — https://console.cloud.google.com
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# CORS / Trusted origins (comma-separated)
# Port 8081 is the default Expo dev server port
TRUSTED_ORIGINS=http://localhost:3000,http://localhost:8081
